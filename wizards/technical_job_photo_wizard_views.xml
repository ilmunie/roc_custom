<?xml version="1.0"?>
<odoo>
    <record id="technical_job_photo_wizard_view" model="ir.ui.view">
        <field name="name">technical.job.photo.wizard.view</field>
        <field name="model">technical.job.photo.wizard</field>
        <field name="arch" type="xml">
            <form string="Fotos de Operacion">
                <field name="photo_stage" invisible="1"/>
                <field name="technical_job_id" invisible="1"/>
                <group>
                    <div class="alert alert-info mb-0" role="alert"
                         attrs="{'invisible': [('photo_stage', '!=', 'initial')]}">
                        <strong>Cargue las fotos del estado inicial del trabajo</strong>
                    </div>
                    <div class="alert alert-warning mb-0" role="alert"
                         attrs="{'invisible': [('photo_stage', '!=', 'final')]}">
                        <strong>Cargue las fotos del estado final del trabajo</strong>
                    </div>
                </group>
                <group>
                    <field name="photo_ids" widget="many2many_binary" string="Fotos"/>
                </group>
                <footer>
                    <button name="action_done" string="Continuar" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
