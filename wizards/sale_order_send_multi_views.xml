<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form view for the wizard -->
    <record id="sale_order_send_multi_form" model="ir.ui.view">
        <field name="name">sale.order.send.multi.form</field>
        <field name="model">sale.order.send.multi</field>
        <field name="arch" type="xml">
            <form string="Envío masivo de presupuestos">
                <group>
                    <field name="partner_id" readonly="1"/>
                    <field name="template_id"/>
                    <field name="subject"/>
                </group>
                <separator string="Resumen de presupuestos"/>
                <field name="order_summary" readonly="1"/>
                <separator string="Cuerpo del correo"/>
                <field name="body"/>
                <field name="order_ids" invisible="1"/>
                <footer>
                    <button name="action_send" type="object" string="Enviar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Server action bound to sale.order list view -->
    <record id="action_sale_order_send_multi" model="ir.actions.act_window">
        <field name="name">Envío masivo de presupuestos</field>
        <field name="res_model">sale.order.send.multi</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_view_types">list</field>
    </record>

</odoo>
