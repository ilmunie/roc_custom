<?xml version="1.0"?>
<odoo>
    <record id="crm_lead_send_quotations_form" model="ir.ui.view">
        <field name="name">crm.lead.send.quotations.form</field>
        <field name="model">crm.lead.send.quotations</field>
        <field name="arch" type="xml">
            <form string="Envío masivo de presupuestos">
                <div class="alert alert-info mb-0" role="alert" attrs="{'invisible': [('partner_count', '&lt;', 2)]}">
                    <strong>Se enviará un correo separado a cada cliente con sus presupuestos correspondientes.</strong>
                </div>
                <group>
                    <field name="partner_count" invisible="1"/>
                    <field name="template_id"/>
                    <field name="subject"/>
                </group>
                <separator string="Presupuestos a enviar"/>
                <field name="order_summary" nolabel="1"/>
                <separator string="Cuerpo del correo"/>
                <field name="body" nolabel="1"/>
                <field name="order_ids" invisible="1"/>
                <field name="lead_ids" invisible="1"/>
                <footer>
                    <button name="action_send" string="Enviar" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_crm_lead_send_quotations" model="ir.actions.act_window">
        <field name="name">Envío masivo de presupuestos</field>
        <field name="res_model">crm.lead.send.quotations</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="crm.model_crm_lead"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>
