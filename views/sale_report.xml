<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Func 3 - Extras section in quotation PDF.
        Appended at the end of the page div in sale.report_saleorder_document.
    -->
    <template id="report_saleorder_extras" inherit_id="sale.report_saleorder_document">
        <xpath expr="//div[hasclass('page')]" position="inside">
            <t t-set="extra_lines" t-value="[
                line for line in doc.order_line
                if not line.display_type and line.product_id and line.product_id.product_tmpl_id.extra_product_config_ids
            ]"/>
            <t t-if="extra_lines">
                <div class="extras-section mt-4" style="page-break-inside: avoid;">
                    <h4 style="border-bottom: 1px solid #888; padding-bottom: 4px; margin-top: 20px;">Productos Extra Disponibles</h4>
                    <t t-foreach="extra_lines" t-as="extra_line">
                        <t t-set="configs" t-value="extra_line.product_id.product_tmpl_id.extra_product_config_ids"/>
                        <t t-if="configs">
                            <div class="mt-2">
                                <strong t-esc="extra_line.product_id.display_name"/>
                                <ul class="mt-1 mb-1" style="font-size:10px; padding-left:18px;">
                                    <t t-foreach="configs" t-as="cfg">
                                        <t t-if="cfg.description">
                                            <li>
                                                <t t-esc="cfg.description"/>
                                                <t t-if="cfg.quantity and cfg.quantity != 1">
                                                    <span style="color:#555;"> x <t t-esc="int(cfg.quantity) if cfg.quantity == int(cfg.quantity) else cfg.quantity"/></span>
                                                </t>
                                            </li>
                                        </t>
                                    </t>
                                </ul>
                            </div>
                        </t>
                    </t>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
